"""Centralised exception handlers.

Wire these up once during app construction:

    from fastapi import FastAPI
    from .handlers import register_exception_handlers

    app = FastAPI()
    register_exception_handlers(app)

Three handlers are registered:

  1. AppError              -> rendered envelope with the error's code
  2. RequestValidationError -> 422 envelope; only field NAMES leak
  3. Exception (catch-all) -> 500 INTERNAL.UNEXPECTED, full traceback
                              logged but never serialised
"""
from __future__ import annotations

import logging

from fastapi import FastAPI, Request
from fastapi.exceptions import RequestValidationError

from .errors import AppError, ErrorCode
from .responses import err

log = logging.getLogger(__name__)


def register_exception_handlers(app: FastAPI) -> None:
    @app.exception_handler(AppError)
    async def _app_error_handler(_request: Request, exc: AppError):
        # `cause` may be None; exc_info=None is a valid call.
        log.warning(
            "app_error",
            extra={
                "code": exc.code.value,
                "params_keys": list(exc.params.keys()),
            },
            exc_info=exc.cause,
        )
        return err(exc)

    @app.exception_handler(RequestValidationError)
    async def _validation_handler(_request: Request, exc: RequestValidationError):
        # Field paths only — values would leak PII (phone, email, names).
        # `loc` starts with "body" / "query" / "path"; we drop that
        # prefix so the frontend sees the user-meaningful field name.
        fields = sorted(
            {".".join(map(str, e["loc"][1:])) for e in exc.errors() if len(e["loc"]) > 1}
        )
        return err(AppError(
            code=ErrorCode.VALIDATION_FAILED,
            params={"fields": fields},
        ))

    @app.exception_handler(Exception)
    async def _unhandled_handler(_request: Request, exc: Exception):
        # Full traceback to logs, generic envelope to the wire. Do NOT
        # echo `str(exc)` to the client — it has been observed to
        # contain SQL fragments, upstream-provider messages with user
        # text, and similar leak vectors.
        log.exception("unhandled_exception")
        return err(AppError(code=ErrorCode.INTERNAL, cause=exc))
