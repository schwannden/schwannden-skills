# gitlint config — enforce Conventional Commits on every commit message.
# Examples that pass:
#   feat(skills): add monitoring-services skill
#   fix(marketplace): correct source path for pr-review
#   docs(readme): refresh skill catalog
#   chore: bump metadata.version to 0.8.0
[general]
# Enable the Conventional Commits title rule (type(scope): subject).
contrib=contrib-title-conventional-commits
# Allow single-line commits (no mandatory body) — most commits here are one line.
ignore=body-is-missing
# Don't run body checks on merge/revert/fixup/squash autogenerated messages.
ignore-merge-commits=true
ignore-revert-commits=true
ignore-fixup-commits=true
ignore-squash-commits=true

[contrib-title-conventional-commits]
# Allowed commit types.
types=feat,fix,docs,chore,refactor,test,style,ci,build,perf,revert

[title-max-length]
line-length=72

[body-max-line-length]
line-length=100
